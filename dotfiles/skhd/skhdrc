# Focus
cmd - h : yabai -m window --focus west
cmd - j : yabai -m window --focus south
cmd - k : yabai -m window --focus north
cmd - l : yabai -m window --focus east

# Move
cmd + shift - h : yabai -m window --warp west
cmd + shift - j : yabai -m window --warp south
cmd + shift - k : yabai -m window --warp north
cmd + shift - l : yabai -m window --warp east

# Resize
cmd + shift - minus : yabai -m window --resize right:-50:0 2>/dev/null || yabai -m window --resize left:-50:0
cmd + shift - equal : yabai -m window --resize right:50:0  2>/dev/null || yabai -m window --resize left:50:0

# Balance - egaleaza toate ferestrele
cmd + shift - b : yabai -m space --balance

# Float / Tile toggle
cmd - space : yabai -m window --toggle float --grid 4:4:1:1:2:2

# Fullscreen
cmd - f : yabai -m window --toggle zoom-fullscreen

# Inchide fereastra
cmd - q : yabai -m window --close
